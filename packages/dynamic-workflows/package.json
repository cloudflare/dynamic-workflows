{
  "name": "@cloudflare/dynamic-workflows",
  "version": "0.1.1",
  "description": "Integrate Cloudflare Workflows with Dynamic Workers by routing workflow execution to tenant-specific dynamic workers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/dynamic-workflows.git",
    "directory": "packages/dynamic-workflows"
  },
  "author": "danlapid",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cloudflare/dynamic-workflows/issues"
  },
  "homepage": "https://github.com/cloudflare/dynamic-workflows/tree/main/packages/dynamic-workflows#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node build.mjs && tsc --emitDeclarationOnly",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "catalog:",
    "esbuild": "^0.27.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ]
}
